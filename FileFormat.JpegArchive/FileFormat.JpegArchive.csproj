<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>FileFormat.JpegArchive</RootNamespace>
    <!-- Multi-target: net10 keeps the CompressionWorkbench descriptor available;
         net8 lets PhotoManager consume the pure-JPEG helpers without dragging
         the whole solution to the latest runtime. -->
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <TargetFramework></TargetFramework>
  </PropertyGroup>

  <!-- Compression.Registry targets net10 only, so the archive-descriptor
       surface compiles in the net10 output. The pure-JPEG helpers
       (segment surgery, future EXIF IFD reader/writer) compile for both. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <ProjectReference Include="..\Compression.Registry\Compression.Registry.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <Compile Remove="JpegArchiveDescriptor.cs" />
  </ItemGroup>

</Project>
