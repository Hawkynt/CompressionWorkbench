<Window x:Class="Compression.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Compression.UI.ViewModels"
        Title="{Binding Title}" Width="900" Height="600" MinWidth="600" MinHeight="400"
        AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver" DragLeave="OnDragLeave"
        WindowStartupLocation="CenterScreen">

  <Window.DataContext>
    <vm:MainViewModel />
  </Window.DataContext>

  <Window.InputBindings>
    <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenCommand}" />
    <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ExtractAllCommand}" />
    <KeyBinding Key="T" Modifiers="Ctrl" Command="{Binding TestCommand}" />
    <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding CreateCommand}" />
    <KeyBinding Key="Back" Command="{Binding NavigateUpCommand}" />
    <KeyBinding Key="Return" Command="{Binding ViewAsTextCommand}" />
    <KeyBinding Key="Return" Modifiers="Alt" Command="{Binding PropertiesCommand}" />
  </Window.InputBindings>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Menu Bar -->
    <Menu Grid.Row="0">
      <MenuItem Header="_File">
        <MenuItem Header="_Open..." Command="{Binding OpenCommand}" InputGestureText="Ctrl+O" />
        <MenuItem Header="_Create..." Command="{Binding CreateCommand}" InputGestureText="Ctrl+N" />
        <MenuItem Header="_Add Files..." Command="{Binding AddFilesCommand}" />
        <Separator />
        <MenuItem Header="E_xit" Click="OnExit" />
      </MenuItem>
      <MenuItem Header="_Actions">
        <MenuItem Header="Extract _All..." Command="{Binding ExtractAllCommand}" InputGestureText="Ctrl+E" />
        <MenuItem Header="Extract _Selected..." Command="{Binding ExtractSelectedCommand}" />
        <MenuItem Header="_Test Integrity" Command="{Binding TestCommand}" InputGestureText="Ctrl+T" />
        <Separator />
        <MenuItem Header="_View as Text" Command="{Binding ViewAsTextCommand}" InputGestureText="Enter" />
        <MenuItem Header="View as _Hex" Command="{Binding ViewAsHexCommand}" />
        <Separator />
        <MenuItem Header="_Properties" Command="{Binding PropertiesCommand}" InputGestureText="Alt+Enter" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_About" Click="OnAbout" />
      </MenuItem>
    </Menu>

    <!-- Toolbar -->
    <ToolBarTray Grid.Row="1">
      <ToolBar Band="0" BandIndex="0">
        <Button Command="{Binding OpenCommand}" ToolTip="Open archive (Ctrl+O)" Padding="8,2">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBlock Text="Open" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Command="{Binding CreateCommand}" ToolTip="Create archive (Ctrl+N)" Padding="8,2">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBlock Text="Create" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Separator />
        <Button Command="{Binding ExtractAllCommand}" ToolTip="Extract all (Ctrl+E)" Padding="8,2">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBlock Text="Extract" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Command="{Binding AddFilesCommand}" ToolTip="Add files to archive" Padding="8,2">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBlock Text="Add" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Command="{Binding TestCommand}" ToolTip="Test integrity (Ctrl+T)" Padding="8,2">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBlock Text="Test" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Separator />
        <Button Command="{Binding NavigateUpCommand}" ToolTip="Go up (Backspace)" Padding="8,2">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBlock Text="Up" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </ToolBar>
    </ToolBarTray>

    <!-- Breadcrumb navigation bar -->
    <Border Grid.Row="2" Padding="4,2" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
            Visibility="{Binding HasArchive, Converter={StaticResource BoolToVisibility}}">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="{Binding Format, Mode=OneWay}" FontWeight="Bold" Foreground="#FF4466AA"
                   VerticalAlignment="Center" Margin="0,0,8,0" />
        <ItemsControl ItemsSource="{Binding Breadcrumbs}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                           VerticalAlignment="Center" Margin="2,0" Foreground="Gray"
                           Visibility="{Binding FolderPath, Converter={StaticResource NonEmptyToVisibility}}" />
                <Button Content="{Binding Label}" Click="OnBreadcrumbClick" Tag="{Binding FolderPath}"
                        Style="{StaticResource BreadcrumbButtonStyle}" />
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <!-- Archive contents list -->
    <ListView Grid.Row="3" ItemsSource="{Binding Entries}" x:Name="EntryList"
              SelectionMode="Extended"
              MouseDoubleClick="OnEntryDoubleClick"
              GridViewColumnHeader.Click="OnColumnHeaderClick">
      <ListView.ContextMenu>
        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
          <MenuItem Header="View as _Text" Command="{Binding ViewAsTextCommand}" InputGestureText="Enter" />
          <MenuItem Header="View as _Hex" Command="{Binding ViewAsHexCommand}" />
          <Separator />
          <MenuItem Header="_Extract Selected..." Command="{Binding ExtractSelectedCommand}" />
          <MenuItem Header="Extract _All..." Command="{Binding ExtractAllCommand}" />
          <Separator />
          <MenuItem Header="_Add Files..." Command="{Binding AddFilesCommand}" />
          <Separator />
          <MenuItem Header="_Properties" Command="{Binding PropertiesCommand}" InputGestureText="Alt+Enter" />
        </ContextMenu>
      </ListView.ContextMenu>
      <ListView.View>
        <GridView>
          <GridViewColumn Header="" Width="30">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{Binding IconColor}" />
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="Name" Width="280" DisplayMemberBinding="{Binding Name}" />
          <GridViewColumn Header="Original" Width="90">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding OriginalSizeText}" TextAlignment="Right" />
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="Compressed" Width="90">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding CompressedSizeText}" TextAlignment="Right" />
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="Ratio" Width="60">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding RatioText}" TextAlignment="Right" />
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="Method" Width="80" DisplayMemberBinding="{Binding MethodText}" />
          <GridViewColumn Header="Modified" Width="130" DisplayMemberBinding="{Binding LastModifiedText}" />
        </GridView>
      </ListView.View>
    </ListView>

    <!-- Drop overlay -->
    <Border Grid.Row="3" x:Name="DropOverlay" Visibility="Collapsed"
            Background="#80000000" IsHitTestVisible="False">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="White"
                   HorizontalAlignment="Center" Margin="0,0,0,8" />
        <TextBlock x:Name="DropText" Foreground="White" FontSize="18"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- Status bar -->
    <StatusBar Grid.Row="4">
      <StatusBarItem>
        <TextBlock Text="{Binding StatusText}" />
      </StatusBarItem>
      <StatusBarItem HorizontalAlignment="Right">
        <ProgressBar Width="120" Height="14" Minimum="0" Maximum="100"
                     Value="{Binding Progress}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
      </StatusBarItem>
    </StatusBar>
  </Grid>
</Window>
