<Window x:Class="Compression.UI.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Compression.UI.Controls"
        Title="Preview" Width="960" Height="640" MinWidth="500" MinHeight="350"
        WindowStartupLocation="CenterOwner" SizeChanged="OnWindowSizeChanged"
        KeyDown="OnWindowKeyDown">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <ToolBarTray Grid.Row="0">
      <ToolBar Band="0" BandIndex="0">
        <RadioButton x:Name="ImageMode" Content="Image" GroupName="Mode"
                     Checked="OnModeChanged" Padding="8,2" Visibility="Collapsed" />
        <RadioButton x:Name="TextMode" Content="Text" IsChecked="True" GroupName="Mode"
                     Checked="OnModeChanged" Padding="8,2" />
        <RadioButton x:Name="HexMode" Content="Hex" GroupName="Mode"
                     Checked="OnModeChanged" Padding="8,2" />
        <Separator />
        <ToggleButton x:Name="WrapToggle" ToolTip="Toggle word wrap" Padding="6,2"
                      Checked="OnWrapChanged" Unchecked="OnWrapChanged">
          <Image Source="{StaticResource ViewTextIcon}" Width="14" Height="14" />
        </ToggleButton>
        <Separator />
        <ComboBox x:Name="EncodingBox" Width="120" SelectionChanged="OnEncodingChanged">
          <ComboBoxItem Content="UTF-8" IsSelected="True" />
          <ComboBoxItem Content="ASCII" />
          <ComboBoxItem Content="Latin-1" />
          <ComboBoxItem Content="UTF-16 LE" />
        </ComboBox>
        <Separator />
        <TextBlock Text="Bytes/row:" VerticalAlignment="Center" Margin="4,0,4,0"
                   Visibility="{Binding ElementName=HexMode, Path=IsChecked, Converter={StaticResource BoolToVisibility}}" />
        <ComboBox x:Name="BytesPerRowBox" Width="55" SelectionChanged="OnBytesPerRowChanged"
                  Visibility="{Binding ElementName=HexMode, Path=IsChecked, Converter={StaticResource BoolToVisibility}}">
          <ComboBoxItem Content="Auto" IsSelected="True" />
          <ComboBoxItem Content="8" />
          <ComboBoxItem Content="16" />
          <ComboBoxItem Content="32" />
          <ComboBoxItem Content="64" />
        </ComboBox>
        <Separator />
        <ToggleButton x:Name="StatsToggle" ToolTip="Toggle statistics panel" Padding="6,2"
                      Checked="OnStatsToggled" Unchecked="OnStatsToggled">
          <Image Source="{StaticResource AnalyzeIcon}" Width="14" Height="14" />
        </ToggleButton>
        <Separator />
        <TextBlock VerticalAlignment="Center" Margin="4,0" x:Name="SizeInfo" />
      </ToolBar>
    </ToolBarTray>

    <!-- Main content area -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition x:Name="SplitterColumn" Width="0" />
        <ColumnDefinition x:Name="StatsColumn" Width="0" />
      </Grid.ColumnDefinitions>

      <!-- Hex view: virtualized listbox -->
      <ListBox Grid.Column="0" x:Name="HexList" Visibility="Collapsed"
               FontFamily="Cascadia Mono,Consolas,Courier New" FontSize="12"
               VirtualizingPanel.IsVirtualizing="True"
               VirtualizingPanel.VirtualizationMode="Recycling"
               VirtualizingPanel.ScrollUnit="Pixel"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               BorderThickness="0"
               ItemsSource="{Binding}"
               SelectionMode="Extended">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <controls:HexLineControl />
          </DataTemplate>
        </ListBox.ItemTemplate>
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="16" />
          </Style>
        </ListBox.ItemContainerStyle>
      </ListBox>

      <!-- Text view: virtualized line list. Backing IList<TextLineViewModel>
           materialises rows on indexer access only — multi-MB previews stay
           fluid because the underlying byte buffer is decoded one visible row
           at a time. (Plain TextBox isn't virtualized; it freezes on big files.) -->
      <ListBox Grid.Column="0" x:Name="ContentBox" Visibility="Collapsed"
               FontFamily="Cascadia Mono,Consolas,Courier New" FontSize="12"
               VirtualizingPanel.IsVirtualizing="True"
               VirtualizingPanel.VirtualizationMode="Recycling"
               VirtualizingPanel.ScrollUnit="Pixel"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               BorderThickness="0"
               ItemsSource="{Binding}"
               SelectionMode="Extended">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Text}" TextWrapping="NoWrap" />
          </DataTemplate>
        </ListBox.ItemTemplate>
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="16" />
          </Style>
        </ListBox.ItemContainerStyle>
      </ListBox>

      <!-- Image view: WPF BitmapImage handles PNG/JPEG/BMP/GIF/TIFF/Ico natively.
           Disabled scrollbars constrain the child to the viewport so Uniform
           stretch can take effect — Auto would hand the child infinity and
           the Image would silently keep its native pixel size. NearestNeighbor
           scaling is the right default for previews: it upscales pixel-art /
           icons / sprites without bilinear blur, and downscaling impact on
           photos is minor at typical viewport sizes. -->
      <ScrollViewer Grid.Column="0" x:Name="ImageScroll"
                    Visibility="Collapsed"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Disabled"
                    Background="#202020">
        <Image x:Name="ImageView" Stretch="Uniform"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               HorizontalAlignment="Center" VerticalAlignment="Center" />
      </ScrollViewer>

      <!-- Resizable splitter for stats panel -->
      <GridSplitter x:Name="StatsSplitter" Grid.Column="1" Width="4" Visibility="Collapsed"
                    HorizontalAlignment="Center" VerticalAlignment="Stretch"
                    Background="LightGray" Cursor="SizeWE" ShowsPreview="True" />

      <!-- Statistics panel (hidden by default) -->
      <Border Grid.Column="2" x:Name="StatsPanel" Visibility="Collapsed"
              BorderBrush="LightGray" BorderThickness="1,0,0,0" Padding="8,4">
        <controls:StatisticsControl x:Name="StatsControl" CompactMode="True" />
      </Border>
    </Grid>

    <!-- Status -->
    <StatusBar Grid.Row="2">
      <StatusBarItem>
        <TextBlock x:Name="SizeLabel" />
      </StatusBarItem>
      <Separator x:Name="FrameNavSeparator" Visibility="Collapsed" />
      <StatusBarItem x:Name="FrameNavPanel" Visibility="Collapsed">
        <StackPanel Orientation="Horizontal">
          <Button x:Name="PrevFrameButton" Content="◀" Padding="6,0" Click="OnPrevFrame"
                  ToolTip="Previous frame (Left arrow)" />
          <Button x:Name="PlayPauseButton" Content="▶" Padding="6,0" Margin="2,0" Click="OnPlayPause"
                  ToolTip="Play / pause animation (Space)" />
          <Button x:Name="NextFrameButton" Content="▶▶" Padding="6,0" Click="OnNextFrame"
                  ToolTip="Next frame (Right arrow)" />
          <TextBlock x:Name="FrameIndexLabel" Margin="10,0,4,0" VerticalAlignment="Center" />
        </StackPanel>
      </StatusBarItem>
    </StatusBar>
  </Grid>
</Window>
