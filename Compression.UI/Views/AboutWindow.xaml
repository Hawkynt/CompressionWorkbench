<Window x:Class="Compression.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About CompressionWorkbench" Width="800" Height="640"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <FlowDocumentScrollViewer Grid.Row="0" x:Name="DocViewer"
                               VerticalScrollBarVisibility="Auto"
                               IsToolBarVisible="False" />

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8">
      <Button Content="Close" Width="80" Padding="4" Click="OnClose" IsDefault="True" IsCancel="True" />
    </StackPanel>
  </Grid>
</Window>
