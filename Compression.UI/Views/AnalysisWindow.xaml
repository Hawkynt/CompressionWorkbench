<Window x:Class="Compression.UI.Views.AnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Compression.UI.Controls"
        Title="Binary Analysis" Width="900" Height="750" MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver">

  <!-- Instant tooltips globally for this window -->
  <Window.Resources>
    <Style TargetType="ToolTip">
      <Setter Property="FontFamily" Value="Consolas" />
      <Setter Property="FontSize" Value="11" />
    </Style>
  </Window.Resources>

  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Row 0: File selection -->
    <GroupBox Grid.Row="0" Header="File" Margin="0,0,0,4">
      <DockPanel Margin="4">
        <Button x:Name="BrowseBtn" DockPanel.Dock="Right" Padding="12,2" Margin="4,0,0,0" Click="OnBrowse">
          <StackPanel Orientation="Horizontal">
            <Image Source="{StaticResource BrowseIcon}" Width="14" Height="14" Margin="0,0,4,0" />
            <TextBlock Text="Browse..." />
          </StackPanel>
        </Button>
        <TextBox x:Name="FilePathBox" IsReadOnly="True" VerticalContentAlignment="Center"
                 Text="Drop a file here or click Browse..." Foreground="Gray" />
      </DockPanel>
    </GroupBox>

    <!-- Row 1: Options -->
    <GroupBox Grid.Row="1" Header="Options" Margin="0,0,0,4">
      <Grid Margin="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <WrapPanel Grid.Row="0" Margin="0,0,0,4">
          <CheckBox x:Name="ChkAll" Content="All" IsChecked="True" Margin="0,0,12,0" Checked="OnAllChecked" Unchecked="OnAllUnchecked" />
          <CheckBox x:Name="ChkDeepScan" Content="Deep Scan" IsChecked="True" Margin="0,0,12,0" />
          <CheckBox x:Name="ChkFingerprint" Content="Fingerprint" IsChecked="True" Margin="0,0,12,0" />
          <CheckBox x:Name="ChkTrial" Content="Trial Decompress" IsChecked="True" Margin="0,0,12,0" />
          <CheckBox x:Name="ChkEntropyMap" Content="Entropy Map" IsChecked="True" Margin="0,0,12,0" />
          <CheckBox x:Name="ChkChain" Content="Chain Reconstruct" IsChecked="True" Margin="0,0,12,0" />
        </WrapPanel>
        <WrapPanel Grid.Row="1">
          <TextBlock Text="Max Depth:" VerticalAlignment="Center" Margin="0,0,4,0" />
          <TextBox x:Name="TxtMaxDepth" Width="40" Text="10" Margin="0,0,12,0" />
          <TextBlock Text="Window:" VerticalAlignment="Center" Margin="0,0,4,0" />
          <TextBox x:Name="TxtWindow" Width="50" Text="256" Margin="0,0,12,0" />
          <TextBlock Text="Offset:" VerticalAlignment="Center" Margin="0,0,4,0" />
          <TextBox x:Name="TxtOffset" Width="70" Text="0" Margin="0,0,12,0" />
          <TextBlock Text="Length:" VerticalAlignment="Center" Margin="0,0,4,0" />
          <TextBox x:Name="TxtLength" Width="70" Text="0" Margin="0,0,12,0" />
          <TextBlock Text="Timeout (ms):" VerticalAlignment="Center" Margin="0,0,4,0" />
          <TextBox x:Name="TxtTimeout" Width="50" Text="200" Margin="0,0,12,0" />
        </WrapPanel>
      </Grid>
    </GroupBox>

    <!-- Row 2: Run button + CLI override + status -->
    <Grid Grid.Row="2" Margin="0,0,0,4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Button x:Name="RunBtn" Grid.Column="0" Padding="16,4" FontWeight="SemiBold" Click="OnRunAnalysis" IsEnabled="False">
        <StackPanel Orientation="Horizontal">
          <Image Source="{StaticResource AnalyzeIcon}" Width="16" Height="16" Margin="0,0,6,0" />
          <TextBlock Text="Run Analysis" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
      <TextBox x:Name="CliOverrideBox" Grid.Column="1" Margin="8,0,0,0" VerticalContentAlignment="Center"
               ToolTip="Optional CLI-style flags, e.g.: --deep-scan --max-depth 5 --offset 1024 --length 4096"
               Text="" Foreground="Gray" GotFocus="OnCliGotFocus" LostFocus="OnCliLostFocus" />
      <TextBlock x:Name="StatusText" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray" Text="" />
    </Grid>

    <!-- Row 3: Results -->
    <Grid Grid.Row="3">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="0,0,0,4">
        <TextBlock x:Name="FileInfoText" FontSize="14" FontWeight="SemiBold" />
        <TextBlock x:Name="StatsSummaryText" FontSize="12" Foreground="Gray" Margin="0,4,0,0" />
      </StackPanel>

      <!-- Tool selector toolbar -->
      <ToolBarTray Grid.Row="1" Margin="0,0,0,2">
        <ToolBar Band="0" BandIndex="0">
          <RadioButton Content="Scan Results" GroupName="AnalysisTool" x:Name="ToolScan"
                       IsChecked="True" Checked="OnToolSelected" Padding="8,2" />
          <RadioButton Content="Fingerprints" GroupName="AnalysisTool" x:Name="ToolFingerprint"
                       Checked="OnToolSelected" Padding="8,2" />
          <RadioButton Content="Entropy Map" GroupName="AnalysisTool" x:Name="ToolEntropy"
                       Checked="OnToolSelected" Padding="8,2" />
          <RadioButton Content="Heatmap" GroupName="AnalysisTool" x:Name="ToolHeatmap"
                       Checked="OnToolSelected" Padding="8,2" />
          <RadioButton Content="Trial Decompress" GroupName="AnalysisTool" x:Name="ToolTrial"
                       Checked="OnToolSelected" Padding="8,2" />
          <RadioButton Content="Chain" GroupName="AnalysisTool" x:Name="ToolChain"
                       Checked="OnToolSelected" Padding="8,2" />
          <Separator />
          <RadioButton Content="Statistics" GroupName="AnalysisTool" x:Name="ToolStats"
                       Checked="OnToolSelected" Padding="8,2" />
          <RadioButton Content="Strings" GroupName="AnalysisTool" x:Name="ToolStrings"
                       Checked="OnToolSelected" Padding="8,2" />
          <RadioButton Content="Structure" GroupName="AnalysisTool" x:Name="ToolStructure"
                       Checked="OnToolSelected" Padding="8,2" />
        </ToolBar>
      </ToolBarTray>

      <!-- Swappable content panels -->
      <Grid Grid.Row="2">

        <!-- Signatures -->
        <DataGrid x:Name="SignaturesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" LoadingRow="OnSignatureRowLoading" Visibility="Visible">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="80" />
            <DataGridTextColumn Header="Format" Binding="{Binding FormatName}" Width="120" />
            <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence, StringFormat=F2}" Width="80" />
            <DataGridTextColumn Header="Magic Len" Binding="{Binding MagicLength}" Width="70" />
            <DataGridTextColumn Header="Header Preview" Binding="{Binding HeaderPreview}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>

        <!-- Fingerprinting -->
        <DataGrid x:Name="FingerprintsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" LoadingRow="OnFingerprintRowLoading" Visibility="Collapsed">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Algorithm" Binding="{Binding Algorithm}" Width="150" />
            <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence, StringFormat=F2}" Width="80" />
            <DataGridTextColumn Header="Explanation" Binding="{Binding Explanation}" Width="*" />
          </DataGrid.Columns>
        </DataGrid>

        <!-- Entropy Map -->
        <Grid x:Name="EntropyPanel" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,4,4,2">
            <Border Width="16" Height="12" Background="#FF2878DC" CornerRadius="1" Margin="0,0,2,0" />
            <TextBlock Text="Plain" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Border Width="16" Height="12" Background="#FF64DCBE" CornerRadius="1" Margin="0,0,2,0" />
            <TextBlock Text="Structured" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Border Width="16" Height="12" Background="#FF64C03C" CornerRadius="1" Margin="0,0,2,0" />
            <TextBlock Text="Light Comp." FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Border Width="16" Height="12" Background="#FFF09628" CornerRadius="1" Margin="0,0,2,0" />
            <TextBlock Text="Dict Comp." FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Border Width="16" Height="12" Background="#FFF02828" CornerRadius="1" Margin="0,0,2,0" />
            <TextBlock Text="Random/Enc." FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0" />
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,2,8,2" />
            <CheckBox x:Name="ChkCUSUM" Content="CUSUM Boundary Detection" IsChecked="False"
                      VerticalAlignment="Center" Checked="OnEntropyModeChanged" Unchecked="OnEntropyModeChanged"
                      ToolTip="Use CUSUM change-point detection instead of adaptive windowing. Better for large files with sharp transitions." />
          </StackPanel>

          <Border Grid.Row="1" Height="28" Margin="4,0,4,4" BorderBrush="#FF888888" BorderThickness="1" CornerRadius="2"
                  ClipToBounds="True" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="30000">
            <Canvas x:Name="EntropyBarCanvas" Background="Transparent"
                    MouseLeftButtonDown="OnEntropyBarClick" SizeChanged="OnEntropyBarSizeChanged" />
          </Border>

          <DataGrid Grid.Row="2" x:Name="EntropyGrid" AutoGenerateColumns="False" IsReadOnly="True"
                    CanUserSortColumns="True" LoadingRow="OnEntropyRowLoading"
                    MouseDoubleClick="OnEntropyGridDoubleClick" SelectionMode="Single">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Offset (hex)" Binding="{Binding Offset, StringFormat=X}" Width="80" />
              <DataGridTextColumn Header="Offset (dec)" Binding="{Binding Offset}" Width="80" />
              <DataGridTextColumn Header="Length" Binding="{Binding Length, StringFormat=N0}" Width="70" />
              <DataGridTextColumn Header="Entropy" Binding="{Binding Entropy, StringFormat=F4}" Width="80" />
              <DataGridTextColumn Header="Chi-sq" Binding="{Binding ChiSquare, StringFormat=F1}" Width="80" />
              <DataGridTextColumn Header="Mean" Binding="{Binding Mean, StringFormat=F1}" Width="60" />
              <DataGridTextColumn Header="Classification" Binding="{Binding Classification}" Width="*" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>

        <!-- Trial Decompression -->
        <Grid x:Name="TrialPanel" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <DataGrid Grid.Row="0" x:Name="TrialGrid" AutoGenerateColumns="False" IsReadOnly="True"
                    CanUserSortColumns="True" SelectionMode="Single"
                    MouseDoubleClick="OnTrialGridDoubleClick" LoadingRow="OnTrialRowLoading">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Algorithm" Binding="{Binding Algorithm}" Width="120" />
              <DataGridTextColumn Header="Output Size" Binding="{Binding OutputSize}" Width="90" />
              <DataGridTextColumn Header="Output Entropy" Binding="{Binding OutputEntropy, StringFormat=F4}" Width="100" />
              <DataGridTextColumn Header="Success" Binding="{Binding Success}" Width="60" />
              <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="*" />
            </DataGrid.Columns>
          </DataGrid>
          <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
            <Button Padding="12,4" Margin="0,0,4,0" Click="OnPreviewTrialOutput">
              <StackPanel Orientation="Horizontal">
                <Image Source="{StaticResource PreviewIcon}" Width="14" Height="14" Margin="0,0,4,0" />
                <TextBlock Text="Preview Output" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Padding="12,4" Click="OnSaveTrialOutput">
              <StackPanel Orientation="Horizontal">
                <Image Source="{StaticResource SaveIcon}" Width="14" Height="14" Margin="0,0,4,0" />
                <TextBlock Text="Save Output..." VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>

        <!-- Chain Reconstruction -->
        <Grid x:Name="ChainPanel" Visibility="Collapsed">
          <DataGrid x:Name="ChainGrid" AutoGenerateColumns="False" IsReadOnly="True"
                    CanUserSortColumns="False" SelectionMode="Single"
                    MouseDoubleClick="OnChainGridDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="#" Binding="{Binding Layer}" Width="30" />
              <DataGridTextColumn Header="Algorithm" Binding="{Binding Algorithm}" Width="200" />
              <DataGridTextColumn Header="Input" Binding="{Binding InputSize}" Width="90" />
              <DataGridTextColumn Header="Output" Binding="{Binding OutputSize}" Width="90" />
              <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence, StringFormat=F2}" Width="80" />
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>

        <!-- Statistics -->
        <controls:StatisticsControl x:Name="AnalysisStatsControl" Visibility="Collapsed" />

        <!-- Strings -->
        <controls:StringSearchControl x:Name="StringsControl" Visibility="Collapsed" />

        <!-- Structure -->
        <controls:StructureViewControl x:Name="StructureControl" Visibility="Collapsed" />

        <!-- Heatmap -->
        <controls:HeatmapGridControl x:Name="HeatmapControl" Visibility="Collapsed" />

      </Grid>
    </Grid>
  </Grid>
</Window>
