<Window x:Class="Compression.UI.Views.FileAssociationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Associations" Width="600" Height="550" MinWidth="450" MinHeight="400"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Row 0: Scope -->
    <GroupBox Grid.Row="0" Header="Registration Scope" Margin="0,0,0,8">
      <StackPanel Margin="4">
        <RadioButton x:Name="RbCurrentUser" Content="Current user only (HKCU)" IsChecked="True" Margin="0,0,0,4" />
        <RadioButton x:Name="RbAllUsers" Content="All users (HKLM — requires administrator)" />
      </StackPanel>
    </GroupBox>

    <!-- Row 1: Quick-select buttons -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
      <Button Content="All" Padding="10,3" Margin="0,0,4,0" Click="OnSelectAll" />
      <Button Content="None" Padding="10,3" Margin="0,0,4,0" Click="OnSelectNone" />
      <Button Content="Common" Padding="10,3" Margin="0,0,4,0" Click="OnSelectCommon"
              ToolTip="Select commonly used formats: zip, 7z, rar, gz, bz2, xz, zst, tar, lz4, cab" />
      <Button Content="Invert" Padding="10,3" Margin="0,0,12,0" Click="OnSelectInvert" />
      <TextBlock x:Name="SelectionCountText" VerticalAlignment="Center" Foreground="Gray" FontSize="11" />
    </StackPanel>

    <!-- Row 2: Extension list -->
    <ListView Grid.Row="2" x:Name="ExtensionList" SelectionMode="Extended"
              ScrollViewer.VerticalScrollBarVisibility="Auto"
              BorderThickness="1" BorderBrush="#CCC">
      <ListView.View>
        <GridView>
          <GridViewColumn Width="30">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding IsSelected}" Click="OnExtCheckChanged" />
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Header="Extension" Width="90" DisplayMemberBinding="{Binding Extension}" />
          <GridViewColumn Header="Format" Width="100" DisplayMemberBinding="{Binding FormatName}" />
          <GridViewColumn Header="Description" Width="300" DisplayMemberBinding="{Binding Description}" />
        </GridView>
      </ListView.View>
    </ListView>

    <!-- Row 3: Context menu options -->
    <GroupBox Grid.Row="3" Header="Context Menu Entries" Margin="0,8,0,8">
      <StackPanel Margin="4">
        <CheckBox x:Name="ChkOpenWith" Content="Open with CompressionWorkbench" IsChecked="True" Margin="0,0,0,4" />
        <CheckBox x:Name="ChkExtractHere" Content="Extract here" IsChecked="True" Margin="0,0,0,4" />
        <CheckBox x:Name="ChkAddToArchive" Content="Add to ZIP/7z archive (on files and folders)" IsChecked="True" />
      </StackPanel>
    </GroupBox>

    <!-- Row 4: Action buttons -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button x:Name="BtnApply" Content="Apply" Padding="16,5" Margin="0,0,8,0" FontWeight="SemiBold"
              Click="OnApply" />
      <Button x:Name="BtnRemoveAll" Content="Remove All" Padding="16,5" Margin="0,0,8,0"
              Click="OnRemoveAll" />
      <Button Content="Close" Padding="16,5" IsCancel="True" Click="OnClose" />
    </StackPanel>
  </Grid>
</Window>
