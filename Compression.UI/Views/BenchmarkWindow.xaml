<Window x:Class="Compression.UI.Views.BenchmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compression Benchmark" Width="1100" Height="750" MinWidth="800" MinHeight="550"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">

  <Window.Resources>
    <Style TargetType="ToolTip">
      <Setter Property="FontFamily" Value="Consolas" />
      <Setter Property="FontSize" Value="11" />
    </Style>
  </Window.Resources>

  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Row 0: Data selection -->
    <GroupBox Grid.Row="0" Header="Test Data" Margin="0,0,0,4">
      <Grid Margin="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <WrapPanel Grid.Row="0" Margin="0,0,0,4">
          <CheckBox x:Name="ChkZeroes" Content="All Zeroes" IsChecked="True" Margin="0,0,12,0"
                    ToolTip="N bytes of 0x00. Best case for RLE and&#10;dictionary compressors — tests maximum&#10;compression ratio on trivial input." />
          <CheckBox x:Name="ChkAlternating" Content="Alternating (0xAA/0x55)" IsChecked="True" Margin="0,0,12,0"
                    ToolTip="Alternates 0xAA and 0x55 (10101010 / 01011010).&#10;Regular 2-byte pattern. Tests how compressors&#10;handle very short repeating cycles." />
          <CheckBox x:Name="ChkIncrementing" Content="Incrementing (0..255)" IsChecked="True" Margin="0,0,12,0"
                    ToolTip="Cycles 0,1,2,...,255,0,1,... (256-byte period).&#10;Predictable but uses all byte values.&#10;Tests delta filters and match finders." />
          <CheckBox x:Name="ChkRepeating" Content="Repeating Pattern" IsChecked="True" Margin="0,0,12,0"
                    ToolTip="Repeats 'ABCDEFGHIJKLMNOP' (16-byte ASCII).&#10;Tests dictionary match distance and&#10;compression of structured text-like data." />
          <CheckBox x:Name="ChkText" Content="English Text" IsChecked="True" Margin="0,0,12,0"
                    ToolTip="Repeated English sentences with natural&#10;word frequency. Realistic workload for&#10;text compressors and context models." />
          <CheckBox x:Name="ChkRandom" Content="Random" IsChecked="True" Margin="0,0,12,0"
                    ToolTip="Cryptographically-style random bytes (seed=42).&#10;Incompressible — measures overhead and&#10;worst-case expansion of each algorithm." />
          <CheckBox x:Name="ChkBinary" Content="Binary Structured" IsChecked="True" Margin="0,0,12,0"
                    ToolTip="Mix of counters, padding zeros, small values,&#10;and random payload in 16-byte records.&#10;Simulates real binary file formats (headers, structs)." />
        </WrapPanel>
        <WrapPanel Grid.Row="1">
          <TextBlock Text="Data Size:" VerticalAlignment="Center" Margin="0,0,4,0" />
          <ComboBox x:Name="CmbDataSize" Width="100" SelectedIndex="4">
            <ComboBoxItem Content="1 KB" Tag="1024" />
            <ComboBoxItem Content="4 KB" Tag="4096" />
            <ComboBoxItem Content="16 KB" Tag="16384" />
            <ComboBoxItem Content="64 KB" Tag="65536" />
            <ComboBoxItem Content="256 KB" Tag="262144" />
            <ComboBoxItem Content="1 MB" Tag="1048576" />
            <ComboBoxItem Content="2 MB" Tag="2097152" />
            <ComboBoxItem Content="4 MB" Tag="4194304" />
            <ComboBoxItem Content="8 MB" Tag="8388608" />
            <ComboBoxItem Content="16 MB" Tag="16777216" />
            <ComboBoxItem Content="32 MB" Tag="33554432" />
            <ComboBoxItem Content="64 MB" Tag="67108864" />
            <ComboBoxItem Content="128 MB" Tag="134217728" />
            <ComboBoxItem Content="256 MB" Tag="268435456" />
            <ComboBoxItem Content="512 MB" Tag="536870912" />
            <ComboBoxItem Content="1 GB" Tag="1073741824" />
          </ComboBox>
          <TextBlock Text="  Iterations:" VerticalAlignment="Center" Margin="8,0,4,0" />
          <ComboBox x:Name="CmbIterations" Width="60" SelectedIndex="1">
            <ComboBoxItem Content="1" Tag="1" />
            <ComboBoxItem Content="3" Tag="3" />
            <ComboBoxItem Content="5" Tag="5" />
            <ComboBoxItem Content="10" Tag="10" />
          </ComboBox>
        </WrapPanel>
      </Grid>
    </GroupBox>

    <!-- Row 1: Algorithm selection with family-colored list -->
    <GroupBox Grid.Row="1" Header="Algorithms" Margin="0,0,0,4" MaxHeight="220">
      <Grid Margin="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,4">
          <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
            <Button Content="All" Padding="6,1" Margin="0,0,3,0" Click="OnSelectAll" FontSize="11" />
            <Button Content="None" Padding="6,1" Margin="0,0,3,0" Click="OnSelectNone" FontSize="11" />
            <Button Content="Invert" Padding="6,1" Margin="0,0,8,0" Click="OnSelectInvert" FontSize="11" />
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,2,8,2" />
            <Button Content="Dictionary" Padding="6,1" Margin="0,0,3,0" Click="OnSelectDictionary" FontSize="11"
                    Background="#E8F0FE" BorderBrush="#B0C4DE" />
            <Button Content="Entropy" Padding="6,1" Margin="0,0,3,0" Click="OnSelectEntropy" FontSize="11"
                    Background="#F0E8FE" BorderBrush="#C4B0DE" />
            <Button Content="Transform" Padding="6,1" Margin="0,0,3,0" Click="OnSelectTransforms" FontSize="11"
                    Background="#E8FEF0" BorderBrush="#B0DEC4" />
            <Button Content="Mixing" Padding="6,1" Margin="0,0,3,0" Click="OnSelectContextMixing" FontSize="11"
                    Background="#FEF0E8" BorderBrush="#DEC4B0" />
            <Button Content="Classic" Padding="6,1" Margin="0,0,3,0" Click="OnSelectClassic" FontSize="11"
                    Background="#FEE8F0" BorderBrush="#DEB0C4" />
            <Button Content="Encoding" Padding="6,1" Margin="0,0,3,0" Click="OnSelectEncoding" FontSize="11"
                    Background="#E8FEFE" BorderBrush="#B0DEDE" />
          </StackPanel>
          <TextBlock x:Name="FormatCountText" DockPanel.Dock="Right" HorizontalAlignment="Right"
                     VerticalAlignment="Center" Foreground="Gray" FontSize="11" />
        </DockPanel>
        <ListView Grid.Row="1" x:Name="FormatListView" SelectionMode="Extended"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  BorderThickness="1" BorderBrush="#CCC" FontSize="11.5">
          <ListView.View>
            <GridView>
              <GridViewColumn Width="30">
                <GridViewColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}" Click="OnFormatCheckChanged" />
                  </DataTemplate>
                </GridViewColumn.CellTemplate>
              </GridViewColumn>
              <GridViewColumn Header="Algorithm" Width="120" DisplayMemberBinding="{Binding DisplayName}" />
              <GridViewColumn Header="Family" Width="90" DisplayMemberBinding="{Binding FamilyName}" />
              <GridViewColumn Header="Description" Width="420" DisplayMemberBinding="{Binding Description}" />
            </GridView>
          </ListView.View>
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="Background" Value="{Binding FamilyBrush}" />
              <Setter Property="Padding" Value="0,1" />
            </Style>
          </ListView.ItemContainerStyle>
        </ListView>
      </Grid>
    </GroupBox>

    <!-- Row 2: Run button + progress -->
    <Grid Grid.Row="2" Margin="0,0,0,4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Button x:Name="RunBtn" Grid.Column="0" Padding="16,4" FontWeight="SemiBold" Click="OnRunBenchmark">
        <StackPanel Orientation="Horizontal">
          <Image Source="{StaticResource TestIcon}" Width="16" Height="16" Margin="0,0,6,0" />
          <TextBlock Text="Run Benchmark" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
      <Button x:Name="StopBtn" Grid.Column="1" Padding="12,4" Margin="4,0,0,0" Click="OnStopBenchmark"
              IsEnabled="False" Content="Stop" />
      <ProgressBar x:Name="ProgressBar" Grid.Column="2" Margin="8,0,0,0" Minimum="0" Maximum="100" />
      <TextBlock x:Name="StatusText" Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray" />
    </Grid>

    <!-- Row 3: Results -->
    <TabControl Grid.Row="3">
      <TabItem Header="Results Table">
        <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" CanUserReorderColumns="True"
                  AlternatingRowBackground="#F8F8F8" GridLinesVisibility="Horizontal"
                  FontFamily="Consolas" FontSize="12">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Algorithm" Binding="{Binding FormatName}" Width="120" />
            <DataGridTextColumn Header="Data Pattern" Binding="{Binding DataPattern}" Width="110" />
            <DataGridTextColumn Header="Original" Binding="{Binding OriginalSizeText}" SortMemberPath="OriginalSize" Width="80">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Compressed" Binding="{Binding CompressedSizeText}" SortMemberPath="CompressedSize" Width="90">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Ratio" Binding="{Binding RatioText}" SortMemberPath="Ratio" Width="65">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Comp. Speed" Binding="{Binding CompressSpeedText}" SortMemberPath="CompressSpeedKBs" Width="100">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Decomp. Speed" Binding="{Binding DecompressSpeedText}" SortMemberPath="DecompressSpeedKBs" Width="110">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Comp. Time" Binding="{Binding CompressTimeText}" SortMemberPath="CompressTimeMs" Width="90">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Decomp. Time" Binding="{Binding DecompressTimeText}" SortMemberPath="DecompressTimeMs" Width="90">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Verified" Binding="{Binding VerifiedText}" Width="60" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
      <TabItem Header="Summary by Algorithm">
        <DataGrid x:Name="SummaryGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" AlternatingRowBackground="#F8F8F8"
                  GridLinesVisibility="Horizontal" FontFamily="Consolas" FontSize="12">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Algorithm" Binding="{Binding FormatName}" Width="120" />
            <DataGridTextColumn Header="Avg Ratio" Binding="{Binding AvgRatioText}" SortMemberPath="AvgRatio" Width="80">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Best Ratio" Binding="{Binding BestRatioText}" SortMemberPath="BestRatio" Width="80">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Avg Comp. Speed" Binding="{Binding AvgCompressSpeedText}" SortMemberPath="AvgCompressSpeedKBs" Width="120">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Avg Decomp. Speed" Binding="{Binding AvgDecompressSpeedText}" SortMemberPath="AvgDecompressSpeedKBs" Width="130">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Tests" Binding="{Binding TestCount}" Width="50">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock"><Setter Property="TextAlignment" Value="Right" /></Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="All OK" Binding="{Binding AllVerifiedText}" Width="60" />
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
    </TabControl>

    <!-- Row 4: Export -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,4,0,0">
      <Button Padding="12,4" Margin="0,0,4,0" Click="OnExportCsv">
        <StackPanel Orientation="Horizontal">
          <Image Source="{StaticResource SaveIcon}" Width="14" Height="14" Margin="0,0,4,0" />
          <TextBlock Text="Export CSV..." VerticalAlignment="Center" />
        </StackPanel>
      </Button>
      <TextBlock x:Name="TotalTimeText" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray" />
    </StackPanel>
  </Grid>
</Window>
