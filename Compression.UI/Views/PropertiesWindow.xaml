<Window x:Class="Compression.UI.Views.PropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Properties" Width="520" Height="780" MinWidth="440" MinHeight="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
  <Grid Margin="0">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="60" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Left compression ratio bar — isometric 3D glass container -->
    <Canvas Grid.Column="0" x:Name="RatioCanvas" Margin="4,12,4,12"
            SizeChanged="OnRatioCanvasSizeChanged" ClipToBounds="False" />

    <!-- Right content area -->
    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
      <StackPanel>

        <!-- File icon + name header -->
        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
          <TextBlock x:Name="EntryIcon" FontFamily="Segoe MDL2 Assets" FontSize="28"
                     VerticalAlignment="Center" Margin="0,0,10,0" />
          <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="EntryName" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="EntryPath" FontSize="11" Foreground="Gray" TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </StackPanel>

        <Separator Margin="0,2,0,8" />

        <!-- General section -->
        <TextBlock Text="General" FontWeight="SemiBold" FontSize="12" Foreground="#FF4466AA" Margin="0,0,0,6" />

        <Grid x:Name="GeneralGrid" Margin="8,0,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Original size:" />
          <TextBlock Grid.Row="0" Grid.Column="1" x:Name="OriginalSizeText" FontWeight="Medium" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Compressed size:" />
          <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CompressedSizeText" FontWeight="Medium" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Compression ratio:" />
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
            <TextBlock x:Name="RatioText" FontWeight="Medium" />
            <TextBlock x:Name="SavingsText" Foreground="Gray" Margin="8,0,0,0" />
          </StackPanel>

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Method:" />
          <TextBlock Grid.Row="3" Grid.Column="1" x:Name="MethodText" FontWeight="Medium" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Last modified:" />
          <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ModifiedText" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Encrypted:" />
          <TextBlock Grid.Row="5" Grid.Column="1" x:Name="EncryptedText" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Type:" />
          <TextBlock Grid.Row="6" Grid.Column="1" x:Name="TypeText" />
        </Grid>

        <Separator Margin="0,10,0,8" />

        <!-- Statistics section (only for files with data) -->
        <StackPanel x:Name="StatisticsPanel" Visibility="Collapsed">

          <!-- Randomness tests -->
          <TextBlock Text="Randomness Tests" FontWeight="SemiBold" FontSize="12" Foreground="#FF4466AA" Margin="0,0,0,6" />
          <Grid Margin="8,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Entropy:" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="EntropyText" FontWeight="Medium" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Arithmetic mean:" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="MeanText" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Chi-square:" />
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ChiSquareText" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Serial correlation:" />
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SerialCorrelationText" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Monte Carlo Pi:" />
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="MonteCarloPiText" />
          </Grid>

          <Separator Margin="0,8,0,8" />

          <!-- Byte distribution -->
          <TextBlock Text="Byte Distribution" FontWeight="SemiBold" FontSize="12" Foreground="#FF4466AA" Margin="0,0,0,6" />
          <Grid Margin="8,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Unique bytes:" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="UniqueBytesText" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Most common:" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="MostCommonText" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Least common:" />
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LeastCommonText" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Ideal size:" />
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="IdealSizeText" Foreground="Gray" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Assessment:" />
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="AssessmentText" FontWeight="SemiBold" />
          </Grid>

          <Separator Margin="0,8,0,8" />

          <!-- N-gram and character class analysis -->
          <TextBlock Text="Content Analysis" FontWeight="SemiBold" FontSize="12" Foreground="#FF4466AA" Margin="0,0,0,6" />
          <Grid Margin="8,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Printable ASCII:" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PrintableAsciiText" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Control bytes:" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ControlBytesText" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="High bytes:" />
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="HighBytesText" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Null bytes:" />
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="NullBytesText" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Unique 2-grams:" />
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="Bigram2Text" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Unique 3-grams:" />
            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="Bigram3Text" />

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Unique 4-grams:" />
            <TextBlock Grid.Row="6" Grid.Column="1" x:Name="Bigram4Text" />
          </Grid>

          <!-- Byte frequency histogram -->
          <TextBlock Text="Byte Frequency Distribution" FontWeight="SemiBold" FontSize="12"
                     Foreground="#FF4466AA" Margin="0,12,0,6" />

          <Border Margin="8,0,0,0" BorderBrush="#FFDDDDDD" BorderThickness="1" CornerRadius="3"
                  ClipToBounds="True">
            <Canvas x:Name="HistogramCanvas" Height="100" ClipToBounds="True" />
          </Border>

          <!-- Histogram legend -->
          <Grid Margin="8,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
              <Border Width="10" Height="10" Background="#FFE06060" CornerRadius="1" Margin="0,0,3,0" />
              <TextBlock Text="Most" FontSize="10" Foreground="Gray" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
              <Border Width="10" Height="10" Background="#FF4CAF50" CornerRadius="1" Margin="0,0,3,0" />
              <TextBlock Text="Least" FontSize="10" Foreground="Gray" />
            </StackPanel>
            <StackPanel Grid.Column="4" Orientation="Horizontal">
              <Border Width="10" Height="10" Background="#30FF9800" CornerRadius="1" Margin="0,0,3,0" />
              <TextBlock Text="Ctrl" FontSize="10" Foreground="Gray" />
            </StackPanel>
            <StackPanel Grid.Column="6" Orientation="Horizontal">
              <Border Width="10" Height="10" Background="#303399FF" CornerRadius="1" Margin="0,0,3,0" />
              <TextBlock Text="ASCII" FontSize="10" Foreground="Gray" />
            </StackPanel>
            <StackPanel Grid.Column="8" Orientation="Horizontal">
              <Border Width="10" Height="10" Background="#309C27B0" CornerRadius="1" Margin="0,0,3,0" />
              <TextBlock Text="High" FontSize="10" Foreground="Gray" />
            </StackPanel>
          </Grid>

          <Separator Margin="0,10,0,8" />
        </StackPanel>

        <!-- Folder statistics (only for directories) -->
        <StackPanel x:Name="FolderStatsPanel" Visibility="Collapsed">
          <TextBlock Text="Contents" FontWeight="SemiBold" FontSize="12" Foreground="#FF4466AA" Margin="0,0,0,6" />

          <Grid Margin="8,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="110" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Files:" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="FileCountText" FontWeight="Medium" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Subdirectories:" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SubdirCountText" />
          </Grid>

          <Separator Margin="0,10,0,8" />
        </StackPanel>

        <!-- OK button -->
        <Button Content="OK" Width="80" HorizontalAlignment="Right" Margin="0,4,0,8"
                Padding="12,4" IsDefault="True" IsCancel="True" Click="OnOk" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
