<Window x:Class="Compression.UI.Views.PropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Properties" Width="520" Height="580" MinWidth="440" MinHeight="480"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
  <Grid Margin="0">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="40" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Left compression ratio bar -->
    <Border Grid.Column="0" Background="#FFE8E8E8" BorderBrush="#FFCCCCCC" BorderThickness="0,0,1,0">
      <Grid Margin="0">
        <!-- Filled portion (bottom-aligned, height = ratio%) -->
        <Border x:Name="RatioBar" Background="#FF3399FF" VerticalAlignment="Bottom" />
        <!-- Ratio text overlay -->
        <TextBlock x:Name="RatioBarText" Text="" FontSize="10" FontWeight="Bold"
                   Foreground="#FF333333" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Margin="0,0,0,4" RenderTransformOrigin="0.5,0.5">
          <TextBlock.LayoutTransform>
            <RotateTransform Angle="-90" />
          </TextBlock.LayoutTransform>
        </TextBlock>
      </Grid>
    </Border>

    <!-- Right content area -->
    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
      <StackPanel>

        <!-- File icon + name header -->
        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
          <TextBlock x:Name="EntryIcon" FontFamily="Segoe MDL2 Assets" FontSize="28"
                     VerticalAlignment="Center" Margin="0,0,10,0" />
          <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="EntryName" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="EntryPath" FontSize="11" Foreground="Gray" TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </StackPanel>

        <Separator Margin="0,2,0,8" />

        <!-- General section -->
        <TextBlock Text="General" FontWeight="SemiBold" FontSize="12" Foreground="#FF4466AA" Margin="0,0,0,6" />

        <Grid x:Name="GeneralGrid" Margin="8,0,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
            <RowDefinition Height="22" />
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="Original size:" />
          <TextBlock Grid.Row="0" Grid.Column="1" x:Name="OriginalSizeText" FontWeight="Medium" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Compressed size:" />
          <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CompressedSizeText" FontWeight="Medium" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="Compression ratio:" />
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
            <TextBlock x:Name="RatioText" FontWeight="Medium" />
            <TextBlock x:Name="SavingsText" Foreground="Gray" Margin="8,0,0,0" />
          </StackPanel>

          <TextBlock Grid.Row="3" Grid.Column="0" Text="Method:" />
          <TextBlock Grid.Row="3" Grid.Column="1" x:Name="MethodText" FontWeight="Medium" />

          <TextBlock Grid.Row="4" Grid.Column="0" Text="Last modified:" />
          <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ModifiedText" />

          <TextBlock Grid.Row="5" Grid.Column="0" Text="Encrypted:" />
          <TextBlock Grid.Row="5" Grid.Column="1" x:Name="EncryptedText" />

          <TextBlock Grid.Row="6" Grid.Column="0" Text="Type:" />
          <TextBlock Grid.Row="6" Grid.Column="1" x:Name="TypeText" />
        </Grid>

        <Separator Margin="0,10,0,8" />

        <!-- Compression ratio visual bar -->
        <TextBlock Text="Compression" FontWeight="SemiBold" FontSize="12" Foreground="#FF4466AA" Margin="0,0,0,6" />

        <Grid Margin="8,0,0,0" Height="28">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="#FFEEEEEE" CornerRadius="3" Height="22">
            <Grid>
              <Border x:Name="RatioVisualBar" Background="#FF3399FF" CornerRadius="3"
                      HorizontalAlignment="Left" Height="22" />
              <TextBlock x:Name="RatioVisualText" HorizontalAlignment="Center" VerticalAlignment="Center"
                         FontSize="11" FontWeight="SemiBold" Foreground="White" />
            </Grid>
          </Border>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
            <Border Width="12" Height="12" Background="#FF3399FF" CornerRadius="2" Margin="0,0,4,0" />
            <TextBlock Text="Compressed" FontSize="10" VerticalAlignment="Center" Foreground="Gray" />
          </StackPanel>
        </Grid>

        <Separator Margin="0,10,0,8" />

        <!-- Statistics section (only for files with data) -->
        <StackPanel x:Name="StatisticsPanel" Visibility="Collapsed">
          <TextBlock Text="Data Statistics" FontWeight="SemiBold" FontSize="12" Foreground="#FF4466AA" Margin="0,0,0,6" />

          <Grid Margin="8,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="110" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Entropy:" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="EntropyText" FontWeight="Medium" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Unique bytes:" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="UniqueBytesText" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Most common:" />
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="MostCommonText" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Ideal size:" />
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="IdealSizeText" Foreground="Gray" />
          </Grid>

          <!-- Byte frequency histogram -->
          <TextBlock Text="Byte Frequency Distribution" FontWeight="SemiBold" FontSize="12"
                     Foreground="#FF4466AA" Margin="0,12,0,6" />

          <Border Margin="8,0,0,0" Background="#FFF8F8F8" BorderBrush="#FFDDDDDD"
                  BorderThickness="1" CornerRadius="3" Padding="4">
            <Canvas x:Name="HistogramCanvas" Height="100" ClipToBounds="True" />
          </Border>

          <!-- Histogram legend -->
          <Grid Margin="8,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="0x00" FontSize="10" Foreground="Gray" HorizontalAlignment="Left" />
            <TextBlock Grid.Column="1" Text="0x80" FontSize="10" Foreground="Gray" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="0xFF" FontSize="10" Foreground="Gray" HorizontalAlignment="Right" />
          </Grid>

          <Separator Margin="0,10,0,8" />
        </StackPanel>

        <!-- Folder statistics (only for directories) -->
        <StackPanel x:Name="FolderStatsPanel" Visibility="Collapsed">
          <TextBlock Text="Contents" FontWeight="SemiBold" FontSize="12" Foreground="#FF4466AA" Margin="0,0,0,6" />

          <Grid Margin="8,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="110" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="22" />
              <RowDefinition Height="22" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Files:" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="FileCountText" FontWeight="Medium" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Subdirectories:" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SubdirCountText" />
          </Grid>

          <Separator Margin="0,10,0,8" />
        </StackPanel>

        <!-- OK button -->
        <Button Content="OK" Width="80" HorizontalAlignment="Right" Margin="0,4,0,8"
                Padding="12,4" IsDefault="True" IsCancel="True" Click="OnOk" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
