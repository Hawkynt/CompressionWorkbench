<Window x:Class="Compression.UI.CreateOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compression Options" Width="480" Height="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolVis" />
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />  <!-- 0: Format label -->
      <RowDefinition Height="Auto" />  <!-- 1: Method -->
      <RowDefinition Height="Auto" />  <!-- 2: Level -->
      <RowDefinition Height="Auto" />  <!-- 3: Dictionary -->
      <RowDefinition Height="Auto" />  <!-- 4: Word size -->
      <RowDefinition Height="Auto" />  <!-- 5: Solid block -->
      <RowDefinition Height="Auto" />  <!-- 6: Threads -->
      <RowDefinition Height="Auto" />  <!-- 7: Password -->
      <RowDefinition Height="Auto" />  <!-- 8: Encryption method -->
      <RowDefinition Height="Auto" />  <!-- 9: Encrypt filenames -->
      <RowDefinition Height="Auto" />  <!-- 10: SFX checkbox -->
      <RowDefinition Height="Auto" />  <!-- 11: SFX type -->
      <RowDefinition Height="Auto" />  <!-- 12: SFX target -->
      <RowDefinition Height="Auto" />  <!-- 13: Memory estimate -->
      <RowDefinition Height="Auto" />  <!-- 14: Description -->
      <RowDefinition Height="*" />     <!-- 15: Spacer -->
      <RowDefinition Height="Auto" />  <!-- 16: Buttons -->
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="110" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Format info -->
    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
               Text="{Binding FormatLabel}" />

    <!-- Method -->
    <TextBlock Grid.Row="1" Grid.Column="0" Text="Method:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowMethod, Converter={StaticResource BoolVis}}" />
    <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
              ItemsSource="{Binding Methods}" SelectedItem="{Binding SelectedMethod}"
              Visibility="{Binding ShowMethod, Converter={StaticResource BoolVis}}" />

    <!-- Level -->
    <TextBlock Grid.Row="2" Grid.Column="0" Text="Level:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowLevel, Converter={StaticResource BoolVis}}" />
    <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
              ItemsSource="{Binding LevelOptions}" SelectedItem="{Binding SelectedLevel}"
              Visibility="{Binding ShowLevel, Converter={StaticResource BoolVis}}" />

    <!-- Dictionary Size (label changes per method) -->
    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding DictSizeLabel}" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowDictSize, Converter={StaticResource BoolVis}}" />
    <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"
              ItemsSource="{Binding DictSizeOptions}" SelectedItem="{Binding SelectedDictSize}"
              Visibility="{Binding ShowDictSize, Converter={StaticResource BoolVis}}" />

    <!-- Word Size -->
    <TextBlock Grid.Row="4" Grid.Column="0" Text="Word size:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowWordSize, Converter={StaticResource BoolVis}}" />
    <ComboBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"
              ItemsSource="{Binding WordSizeOptions}" SelectedItem="{Binding SelectedWordSize}"
              Visibility="{Binding ShowWordSize, Converter={StaticResource BoolVis}}" />

    <!-- Solid Block Size -->
    <TextBlock Grid.Row="5" Grid.Column="0" Text="Solid block:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowSolidSize, Converter={StaticResource BoolVis}}" />
    <ComboBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,8"
              ItemsSource="{Binding SolidSizeOptions}" SelectedItem="{Binding SelectedSolidSize}"
              Visibility="{Binding ShowSolidSize, Converter={StaticResource BoolVis}}" />

    <!-- Threads -->
    <TextBlock Grid.Row="6" Grid.Column="0" Text="Threads:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowThreads, Converter={StaticResource BoolVis}}" />
    <ComboBox Grid.Row="6" Grid.Column="1" Margin="0,0,0,8"
              ItemsSource="{Binding ThreadOptions}" SelectedItem="{Binding SelectedThreads}"
              Visibility="{Binding ShowThreads, Converter={StaticResource BoolVis}}" />

    <!-- Password -->
    <TextBlock Grid.Row="7" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowPassword, Converter={StaticResource BoolVis}}" />
    <PasswordBox Grid.Row="7" Grid.Column="1" x:Name="PasswordBox" Margin="0,0,0,8"
                 PasswordChanged="OnPasswordChanged"
                 Visibility="{Binding ShowPassword, Converter={StaticResource BoolVis}}"
                 IsEnabled="{Binding PasswordEnabled}" />

    <!-- Encryption method -->
    <TextBlock Grid.Row="8" Grid.Column="0" Text="Encryption:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowEncryptionMethod, Converter={StaticResource BoolVis}}" />
    <ComboBox Grid.Row="8" Grid.Column="1" Margin="0,0,0,8"
              ItemsSource="{Binding EncryptionMethodOptions}" SelectedItem="{Binding SelectedEncryptionMethod}"
              IsEnabled="{Binding PasswordEnabled}"
              Visibility="{Binding ShowEncryptionMethod, Converter={StaticResource BoolVis}}" />

    <!-- Encrypt filenames -->
    <TextBlock Grid.Row="9" Grid.Column="0" Text="Headers:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowEncryptFilenames, Converter={StaticResource BoolVis}}" />
    <CheckBox Grid.Row="9" Grid.Column="1" IsChecked="{Binding EncryptFilenames}" Content="Encrypt file names"
              VerticalAlignment="Center" Margin="0,0,0,8"
              IsEnabled="{Binding PasswordEnabled}"
              Visibility="{Binding ShowEncryptFilenames, Converter={StaticResource BoolVis}}" />

    <!-- SFX -->
    <TextBlock Grid.Row="10" Grid.Column="0" Text="SFX:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowSfx, Converter={StaticResource BoolVis}}" />
    <CheckBox Grid.Row="10" Grid.Column="1" IsChecked="{Binding MakeSfx}" Content="Self-extracting archive"
              VerticalAlignment="Center" Margin="0,0,0,8"
              Visibility="{Binding ShowSfx, Converter={StaticResource BoolVis}}" />

    <!-- SFX Type -->
    <TextBlock Grid.Row="11" Grid.Column="0" Text="SFX type:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowSfxOptions, Converter={StaticResource BoolVis}}" />
    <ComboBox Grid.Row="11" Grid.Column="1" Margin="0,0,0,8"
              ItemsSource="{Binding SfxTypeOptions}" SelectedItem="{Binding SelectedSfxType}"
              Visibility="{Binding ShowSfxOptions, Converter={StaticResource BoolVis}}" />

    <!-- SFX Target -->
    <TextBlock Grid.Row="12" Grid.Column="0" Text="SFX target:" VerticalAlignment="Center" Margin="0,0,0,8"
               Visibility="{Binding ShowSfxOptions, Converter={StaticResource BoolVis}}" />
    <ComboBox Grid.Row="12" Grid.Column="1" Margin="0,0,0,8"
              ItemsSource="{Binding SfxTargetOptions}" SelectedItem="{Binding SelectedSfxTarget}"
              Visibility="{Binding ShowSfxOptions, Converter={StaticResource BoolVis}}" />

    <!-- Memory Estimate -->
    <Border Grid.Row="13" Grid.ColumnSpan="2" Margin="0,4,0,4" Padding="8,4" CornerRadius="3"
            Background="{Binding MemoryBackground}"
            Visibility="{Binding ShowMemoryEstimate, Converter={StaticResource BoolVis}}">
      <TextBlock FontSize="11.5" FontWeight="SemiBold"
                 Foreground="{Binding MemoryBrush}"
                 Text="{Binding MemoryEstimate}" />
    </Border>

    <!-- Description -->
    <Border Grid.Row="14" Grid.ColumnSpan="2" Margin="0,4,0,0" Padding="8,6" CornerRadius="4"
            Background="#F0F0F0">
      <TextBlock Foreground="#555" TextWrapping="Wrap" FontSize="11.5"
                 Text="{Binding HintText}" />
    </Border>

    <!-- Buttons -->
    <StackPanel Grid.Row="16" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right"
                Margin="0,8,0,0">
      <Button Content="Create" Width="90" Margin="0,0,8,0" IsDefault="True" Click="OnCreate"
              Padding="4,6" FontWeight="SemiBold" />
      <Button Content="Cancel" Width="90" IsCancel="True" Padding="4,6" />
    </StackPanel>
  </Grid>
</Window>
