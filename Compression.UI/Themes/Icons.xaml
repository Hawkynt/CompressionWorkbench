<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ===== File list icons (16x16) ===== -->

  <!-- Yellow folder icon -->
  <DrawingImage x:Key="FolderIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <!-- Folder back -->
        <GeometryDrawing Brush="#FFD4A017" Geometry="M 1,4 L 1,14 L 15,14 L 15,6 L 8,6 L 6,4 Z" />
        <!-- Folder front -->
        <GeometryDrawing Brush="#FFFFC846" Geometry="M 1,7 L 1,14 L 15,14 L 15,7 Z" />
        <!-- Folder tab -->
        <GeometryDrawing Brush="#FFE8B830" Geometry="M 1,4 L 6,4 L 8,6 L 1,6 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- White/light file icon -->
  <DrawingImage x:Key="FileIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <!-- Page body -->
        <GeometryDrawing Brush="#FFF0F2F5" Geometry="M 3,1 L 3,15 L 13,15 L 13,5 L 9,1 Z">
          <GeometryDrawing.Pen><Pen Brush="#FF9EAAB8" Thickness="0.5" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <!-- Corner fold -->
        <GeometryDrawing Brush="#FFD0D8E0" Geometry="M 9,1 L 9,5 L 13,5 Z" />
        <!-- Text lines -->
        <GeometryDrawing Brush="#FFBCC4CC" Geometry="M 5,7 L 11,7 L 11,7.7 L 5,7.7 Z" />
        <GeometryDrawing Brush="#FFBCC4CC" Geometry="M 5,9 L 11,9 L 11,9.7 L 5,9.7 Z" />
        <GeometryDrawing Brush="#FFBCC4CC" Geometry="M 5,11 L 9,11 L 9,11.7 L 5,11.7 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Locked file icon -->
  <DrawingImage x:Key="LockedFileIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <!-- Page body -->
        <GeometryDrawing Brush="#FFF5EDED" Geometry="M 3,1 L 3,15 L 13,15 L 13,5 L 9,1 Z">
          <GeometryDrawing.Pen><Pen Brush="#FFBB7777" Thickness="0.5" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Brush="#FFE0C8C8" Geometry="M 9,1 L 9,5 L 13,5 Z" />
        <!-- Lock body -->
        <GeometryDrawing Brush="#FFCC4444" Geometry="M 6,9 L 6,13 L 10,13 L 10,9 Z" />
        <!-- Lock shackle -->
        <GeometryDrawing Geometry="M 6.8,9 L 6.8,7.5 A 1.2,1.2 0 0 1 9.2,7.5 L 9.2,9">
          <GeometryDrawing.Pen><Pen Brush="#FFCC4444" Thickness="1" /></GeometryDrawing.Pen>
        </GeometryDrawing>
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Up arrow icon -->
  <DrawingImage x:Key="UpArrowIcon">
    <DrawingImage.Drawing>
      <GeometryDrawing Brush="#FF4488CC" Geometry="M 8,2 L 3,9 L 6,9 L 6,14 L 10,14 L 10,9 L 13,9 Z" />
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- ===== Menu / toolbar icons (16x16) ===== -->

  <!-- Open folder -->
  <DrawingImage x:Key="OpenIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FFD4A017" Geometry="M 1,4 L 1,13 L 4,13 L 6,7 L 13,7 L 13,6 L 7,6 L 5,4 Z" />
        <GeometryDrawing Brush="#FFFFC846" Geometry="M 4,13 L 6,7 L 15,7 L 13,13 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Create / new -->
  <DrawingImage x:Key="CreateIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FFF0F2F5" Geometry="M 3,1 L 3,15 L 13,15 L 13,5 L 9,1 Z">
          <GeometryDrawing.Pen><Pen Brush="#FF9EAAB8" Thickness="0.5" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Brush="#FFD0D8E0" Geometry="M 9,1 L 9,5 L 13,5 Z" />
        <GeometryDrawing Brush="#FF44AA44" Geometry="M 7.5,7 L 8.5,7 L 8.5,9.5 L 11,9.5 L 11,10.5 L 8.5,10.5 L 8.5,13 L 7.5,13 L 7.5,10.5 L 5,10.5 L 5,9.5 L 7.5,9.5 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Add files -->
  <DrawingImage x:Key="AddIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FF4488CC" Geometry="M 7,3 L 9,3 L 9,7 L 13,7 L 13,9 L 9,9 L 9,13 L 7,13 L 7,9 L 3,9 L 3,7 L 7,7 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Extract / download -->
  <DrawingImage x:Key="ExtractIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FF4488CC" Geometry="M 7,2 L 9,2 L 9,9 L 12,9 L 8,14 L 4,9 L 7,9 Z" />
        <GeometryDrawing Brush="#FF4488CC" Geometry="M 2,13 L 2,15 L 14,15 L 14,13 L 12,13 L 12,14 L 4,14 L 4,13 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Extract selected -->
  <DrawingImage x:Key="ExtractSelectedIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FF4488CC" Geometry="M 7,2 L 9,2 L 9,7 L 11,7 L 8,11 L 5,7 L 7,7 Z" />
        <GeometryDrawing Brush="#FF4488CC" Geometry="M 2,13 L 2,15 L 14,15 L 14,13 L 12,13 L 12,14 L 4,14 L 4,13 Z" />
        <GeometryDrawing Brush="#FF44AA44" Geometry="M 11,1 L 13,3 L 15,1 L 14,0 L 13,1 L 12,0 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Test / checkmark -->
  <DrawingImage x:Key="TestIcon">
    <DrawingImage.Drawing>
      <GeometryDrawing Brush="#FF44AA44" Geometry="M 2,8 L 4,6 L 7,9 L 13,3 L 15,5 L 7,13 Z" />
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- View text -->
  <DrawingImage x:Key="ViewTextIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FF6688AA" Geometry="M 2,3 L 14,3 L 14,3.8 L 2,3.8 Z" />
        <GeometryDrawing Brush="#FF6688AA" Geometry="M 2,5.5 L 14,5.5 L 14,6.3 L 2,6.3 Z" />
        <GeometryDrawing Brush="#FF6688AA" Geometry="M 2,8 L 14,8 L 14,8.8 L 2,8.8 Z" />
        <GeometryDrawing Brush="#FF6688AA" Geometry="M 2,10.5 L 10,10.5 L 10,11.3 L 2,11.3 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- View hex -->
  <DrawingImage x:Key="ViewHexIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FF667799" Geometry="M 1,2 L 15,2 L 15,14 L 1,14 Z">
          <GeometryDrawing.Pen><Pen Brush="#FF556688" Thickness="0.5" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Brush="#FF334466" Geometry="M 2,4 L 5,4 L 5,4.7 L 2,4.7 Z" />
        <GeometryDrawing Brush="#FF556688" Geometry="M 6,4 L 14,4 L 14,4.7 L 6,4.7 Z" />
        <GeometryDrawing Brush="#FF334466" Geometry="M 2,6.5 L 5,6.5 L 5,7.2 L 2,7.2 Z" />
        <GeometryDrawing Brush="#FF556688" Geometry="M 6,6.5 L 14,6.5 L 14,7.2 L 6,7.2 Z" />
        <GeometryDrawing Brush="#FF334466" Geometry="M 2,9 L 5,9 L 5,9.7 L 2,9.7 Z" />
        <GeometryDrawing Brush="#FF556688" Geometry="M 6,9 L 14,9 L 14,9.7 L 6,9.7 Z" />
        <GeometryDrawing Brush="#FF334466" Geometry="M 2,11.5 L 5,11.5 L 5,12.2 L 2,12.2 Z" />
        <GeometryDrawing Brush="#FF556688" Geometry="M 6,11.5 L 14,11.5 L 14,12.2 L 6,12.2 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Properties / gear -->
  <DrawingImage x:Key="PropertiesIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FF6688AA" Geometry="M 7,1 L 9,1 L 9.5,3 L 11,3.5 L 13,2 L 14,3 L 12.5,5 L 13,6.5 L 15,7 L 15,9 L 13,9.5 L 12.5,11 L 14,13 L 13,14 L 11,12.5 L 9.5,13 L 9,15 L 7,15 L 6.5,13 L 5,12.5 L 3,14 L 2,13 L 3.5,11 L 3,9.5 L 1,9 L 1,7 L 3,6.5 L 3.5,5 L 2,3 L 3,2 L 5,3.5 L 6.5,3 Z" />
        <GeometryDrawing Brush="#FFFFFFFF" Geometry="M 8,6 A 2,2 0 1 1 7.99,6 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Analyze / magnifier with chart -->
  <DrawingImage x:Key="AnalyzeIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <!-- Magnifying glass -->
        <GeometryDrawing Geometry="M 7,2 A 5,5 0 1 0 7,11.99 A 5,5 0 1 0 7,2 Z">
          <GeometryDrawing.Pen><Pen Brush="#FF4488CC" Thickness="1.5" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <!-- Handle -->
        <GeometryDrawing Brush="#FF4488CC" Geometry="M 10.5,11 L 14,14.5 L 15,13.5 L 11.5,10 Z" />
        <!-- Mini bar chart inside lens -->
        <GeometryDrawing Brush="#FF66AADD" Geometry="M 4,9 L 5,9 L 5,6 L 4,6 Z" />
        <GeometryDrawing Brush="#FF66AADD" Geometry="M 6,9 L 7,9 L 7,4 L 6,4 Z" />
        <GeometryDrawing Brush="#FF66AADD" Geometry="M 8,9 L 9,9 L 9,7 L 8,7 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Up / navigate up -->
  <DrawingImage x:Key="NavigateUpIcon">
    <DrawingImage.Drawing>
      <GeometryDrawing Brush="#FF4488CC" Geometry="M 8,2 L 14,8 L 11,8 L 11,14 L 5,14 L 5,8 L 2,8 Z" />
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Exit -->
  <DrawingImage x:Key="ExitIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Geometry="M 2,2 L 9,2 L 9,5 L 8,5 L 8,3 L 3,3 L 3,13 L 8,13 L 8,11 L 9,11 L 9,14 L 2,14 Z">
          <GeometryDrawing.Pen><Pen Brush="#FFCC4444" Thickness="0.3" /></GeometryDrawing.Pen>
        </GeometryDrawing>
        <GeometryDrawing Brush="#FFCC4444" Geometry="M 2,2 L 9,2 L 9,5 L 8,5 L 8,3 L 3,3 L 3,13 L 8,13 L 8,11 L 9,11 L 9,14 L 2,14 Z" />
        <GeometryDrawing Brush="#FFCC4444" Geometry="M 7,7 L 13,7 L 13,5 L 16,8 L 13,11 L 13,9 L 7,9 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- About / info -->
  <DrawingImage x:Key="AboutIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FF4488CC" Geometry="M 8,1 A 7,7 0 1 0 8,14.99 A 7,7 0 1 0 8,1 Z" />
        <GeometryDrawing Brush="#FFFFFFFF" Geometry="M 7.2,5 L 8.8,5 L 8.8,6.5 L 7.2,6.5 Z" />
        <GeometryDrawing Brush="#FFFFFFFF" Geometry="M 7.2,7.5 L 8.8,7.5 L 8.8,12 L 7.2,12 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Save / floppy disk -->
  <DrawingImage x:Key="SaveIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FF4488CC" Geometry="M 2,1 L 2,15 L 14,15 L 14,4 L 11,1 Z" />
        <GeometryDrawing Brush="#FFFFFFFF" Geometry="M 4,1 L 4,5 L 10,5 L 10,1 Z" />
        <GeometryDrawing Brush="#FFFFFFFF" Geometry="M 4,9 L 12,9 L 12,14 L 4,14 Z" />
        <GeometryDrawing Brush="#FF4488CC" Geometry="M 8,2 L 9,2 L 9,4 L 8,4 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Preview / eye -->
  <DrawingImage x:Key="PreviewIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FF6688AA" Geometry="M 1,8 Q 8,2 15,8 Q 8,14 1,8 Z" />
        <GeometryDrawing Brush="#FFFFFFFF" Geometry="M 8,5 A 3,3 0 1 0 8,10.99 A 3,3 0 1 0 8,5 Z" />
        <GeometryDrawing Brush="#FF334466" Geometry="M 8,6.5 A 1.5,1.5 0 1 0 8,9.49 A 1.5,1.5 0 1 0 8,6.5 Z" />
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

  <!-- Browse / folder open outline -->
  <DrawingImage x:Key="BrowseIcon">
    <DrawingImage.Drawing>
      <DrawingGroup>
        <GeometryDrawing Brush="#FFD4A017" Geometry="M 1,4 L 1,13 L 4,13 L 6,7 L 13,7 L 13,6 L 7,6 L 5,4 Z" />
        <GeometryDrawing Brush="#FFFFC846" Geometry="M 4,13 L 6,7 L 15,7 L 13,13 Z" />
        <GeometryDrawing Brush="#FF4488CC" Geometry="M 11,1 L 13,3 L 15,1" >
          <GeometryDrawing.Pen><Pen Brush="#FF4488CC" Thickness="1" /></GeometryDrawing.Pen>
        </GeometryDrawing>
      </DrawingGroup>
    </DrawingImage.Drawing>
  </DrawingImage>

</ResourceDictionary>
