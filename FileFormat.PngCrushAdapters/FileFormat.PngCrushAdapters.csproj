<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>FileFormat.PngCrushAdapters</RootNamespace>
    <!--
      Adapter project for the sibling PngCrushCS repo. When that repo is checked
      out at ..\..\PNGCrushCS, this project compiles the adapter sources and
      pulls in its descriptors (Apng/Tiff/Mpo/etc.). When the sibling is
      ABSENT (e.g. on CI runners), the project produces an empty assembly
      so the .slnx still builds cleanly.
    -->
    <SiblingPresent>false</SiblingPresent>
    <SiblingPresent Condition="Exists('$(MSBuildThisFileDirectory)..\..\PNGCrushCS\FileFormat.Core\FileFormat.Core.csproj')">true</SiblingPresent>
    <!-- Suppress default *.cs compile globbing when sibling is absent so adapter sources don't try to build. -->
    <EnableDefaultCompileItems Condition="'$(SiblingPresent)' != 'true'">false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Compression.Registry\Compression.Registry.csproj" />
    <!-- GIF reader/decoder lives in FileFormat.Gif (dependency-free); the
         color-aware GIF descriptor here uses GifPixelDecoder + the colorspace
         pipeline. Always reference it (no sibling guard) so projects that DO
         have the sibling get the rich descriptor without conditional plumbing. -->
    <ProjectReference Include="..\FileFormat.Gif\FileFormat.Gif.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(SiblingPresent)' == 'true'">
    <!-- PngCrushCS's FileFormat.Png references System.IO.Hashing transitively; declare it
         here so the .NET 10 host can resolve the assembly at runtime. -->
    <PackageReference Include="System.IO.Hashing" Version="9.0.4" />
  </ItemGroup>

  <ItemGroup Condition="'$(SiblingPresent)' == 'true'">
    <!-- Cross-repo: PngCrushCS's image format library. -->
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Core\FileFormat.Core.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Png\FileFormat.Png.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Bmp\FileFormat.Bmp.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Apng\FileFormat.Apng.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Tiff\FileFormat.Tiff.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.BigTiff\FileFormat.BigTiff.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Mng\FileFormat.Mng.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Fli\FileFormat.Fli.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Dcx\FileFormat.Dcx.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Icns\FileFormat.Icns.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Mpo\FileFormat.Mpo.csproj" />
    <ProjectReference Include="..\..\PNGCrushCS\FileFormat.Jpeg\FileFormat.Jpeg.csproj" />
  </ItemGroup>

</Project>
