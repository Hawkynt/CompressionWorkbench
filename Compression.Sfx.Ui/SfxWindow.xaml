<Window x:Class="Compression.Sfx.Ui.SfxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Self-Extracting Archive" Height="280" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="FormatLabel" FontSize="16" FontWeight="Bold"
                   Text="Self-Extracting Archive" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="OutputPathBox" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="Browse..." Click="OnBrowse" Padding="12,4"/>
        </Grid>

        <ProgressBar Grid.Row="4" x:Name="ProgressBar" Height="24" Minimum="0" Maximum="100" />

        <TextBlock Grid.Row="6" x:Name="StatusLabel" Text="Choose a destination folder and click Extract."
                   TextWrapping="Wrap" Foreground="Gray" />

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ExtractButton" Content="Extract" Click="OnExtract"
                    Padding="20,6" IsDefault="True" />
            <Button Content="Close" Click="OnClose" Padding="20,6" Margin="10,0,0,0" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
